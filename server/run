#!/usr/bin/env bash
# Launch the Gopher Eye API + chatbot in Docker.
#
# The chatbot is part of the API process — it's enabled by setting
# GOPHER_EYE_LLM_CKPT (and GOPHER_EYE_LLM_DIR) before the server boots. This
# script wires those env vars and the matching volume mounts into a single
# `docker run` invocation so /dl/* and /v1/chat/completions come up together.
#
# Usage:
#   server/run                       # build if needed, then run in the foreground
#   server/run -d                    # detached
#   LLM_CKPT=/abs/path server/run    # override the checkpoint
#   PORT=5556 server/run             # publish a different host port
#   HOST_IP=0.0.0.0 server/run       # publish on all interfaces (default: 10.0.1.10)
#
# Stop with Ctrl-C (foreground) or `docker stop gopher-eye-server` (detached).

set -euo pipefail

SERVER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SERVER_DIR/.." && pwd)"
cd "$SERVER_DIR"

IMAGE="${IMAGE:-gopher-eye-server}"
CONTAINER="${CONTAINER:-gopher-eye-server}"
PORT="${PORT:-5000}"
# Host IP to bind the published port to. Defaults to the ZeroTier interface
# (10.0.1.10) so peers on the 10.0.1.0/24 overlay can reach the server.
# Use HOST_IP=0.0.0.0 to expose on every interface, or HOST_IP=127.0.0.1 for
# localhost-only.
HOST_IP="${HOST_IP:-10.0.1.10}"

# Where the BLIP_Qwen checkpoint and LLM source live on the host. Default to
# the layout produced by LLM_work/how_to_use/assemble_model_demo.py.
LLM_CKPT="${LLM_CKPT:-$REPO_ROOT/LLM_work/qwen3-1.7B-greenhouse-ngld-faithful-stage2}"
LLM_DIR="${LLM_DIR:-$REPO_ROOT/LLM_work}"

# Host path that the swinv2 classifier symlink under server/models/ resolves to.
# Mounted into the container at the same absolute path so the symlink stays valid.
SWIN_DIR="${SWIN_DIR:-/home/nickp/development/grape/hf-models/swinv2-tiny-patch4-window8-256/checkpoint-100}"

# HuggingFace cache on the host — bind-mounted into /root/.cache/huggingface
# so the container's transformers runtime finds the pre-downloaded SAM 3
# weights (~3.3 GB) and the gated-model token without redownloading.
# RW (not RO) because transformers wants to write its own metadata
# (.no_exist markers, lock files) into the cache during load.
HF_CACHE="${HF_CACHE:-$HOME/.cache/huggingface}"

if [ ! -d "$LLM_CKPT" ]; then
  echo "error: chatbot checkpoint not found: $LLM_CKPT" >&2
  echo "       set LLM_CKPT=/abs/path/to/checkpoint and retry" >&2
  exit 1
fi
if [ ! -d "$LLM_DIR" ]; then
  echo "error: LLM source root not found: $LLM_DIR" >&2
  echo "       set LLM_DIR=/abs/path/to/LLM_work and retry" >&2
  exit 1
fi
if [ ! -d "$SWIN_DIR" ]; then
  echo "error: swinv2 classifier dir not found: $SWIN_DIR" >&2
  echo "       set SWIN_DIR=/abs/path/to/checkpoint and retry" >&2
  exit 1
fi

if [[ -z "$(docker images -q "$IMAGE" 2>/dev/null)" ]]; then
  echo "Building docker image '$IMAGE'..."
  docker build -t "$IMAGE" .
fi

# If a previous run left a container behind, replace it so the new env vars
# and mounts take effect.
if [[ -n "$(docker ps -aq -f name="^${CONTAINER}$" 2>/dev/null)" ]]; then
  docker rm -f "$CONTAINER" >/dev/null
fi

RUN_MODE=("--rm" "-it")
for arg in "$@"; do
  if [[ "$arg" == "-d" || "$arg" == "--detach" ]]; then
    RUN_MODE=("-d")
    break
  fi
done

echo "Starting $CONTAINER on $HOST_IP:$PORT (api + chatbot)"
echo "  LLM_CKPT: $LLM_CKPT"
echo "  LLM_DIR:  $LLM_DIR"

exec docker run \
  "${RUN_MODE[@]}" \
  --name "$CONTAINER" \
  -p "${HOST_IP}:${PORT}:5000" \
  -e GOPHER_EYE_LLM_CKPT=/llm/ckpt \
  -e GOPHER_EYE_LLM_DIR=/llm/src \
  -v "$SERVER_DIR/app:/app" \
  -v "$SERVER_DIR/plants:/app/plants" \
  -v "$SERVER_DIR/images:/app/images" \
  -v "$SERVER_DIR/models:/app/models" \
  -v "$SERVER_DIR/runs:/app/runs:ro" \
  -v "$SERVER_DIR/trials:/app/trials" \
  -v "$SERVER_DIR/data:/app/data" \
  -v "$LLM_CKPT:/llm/ckpt:ro" \
  -v "$LLM_DIR:/llm/src:ro" \
  -v "$SWIN_DIR:$SWIN_DIR:ro" \
  -v "$HF_CACHE:/root/.cache/huggingface" \
  "$IMAGE"
